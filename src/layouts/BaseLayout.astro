---
import "../styles/global.css";
import { profile } from "../config/config";

interface Props {
  title?: string;
}

const { title = `${profile.name} - CV` } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link
      rel="preload"
      href="/fonts/SourceSans3-VariableFont_wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SourceSerif4-VariableFont_wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
  </head>
  <body class="bg-neutral-100 text-neutral-900 print:bg-white font-body">
    <slot />
  </body>
</html>
