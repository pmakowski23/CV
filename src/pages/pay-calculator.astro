---
import BaseLayout from "../layouts/BaseLayout.astro";
import PayCalculatorForm from "../components/PayCalculatorForm";
---

<BaseLayout title="Pay Calculator">
  <main
    class="min-h-screen px-4 py-10 bg-[radial-gradient(circle_at_10%_15%,#fef3c7_0%,#f8fafc_40%,#e0f2fe_100%)]"
  >
    <div class="mx-auto max-w-5xl">
      <header class="mb-8">
        <p class="uppercase tracking-[0.2em] text-xs text-neutral-600 font-semibold">
          Compensation
        </p>
        <h1 class="mt-2 text-4xl font-heading font-extrabold text-neutral-900">
          Pay Calculator
        </h1>
        <p class="mt-3 text-neutral-700 max-w-3xl">
          Enter a suggested rate in any format. The other salary inputs stay in
          sync. Add paid free days and sick days to calculate combined
          compensation.
        </p>
      </header>

      <PayCalculatorForm client:load />
    </div>
  </main>
</BaseLayout>
